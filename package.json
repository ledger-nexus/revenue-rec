{
  "name": "revenue-rec",
  "version": "0.1.0",
  "private": true,
  "description": "ASC 606 revenue recognition engine. AI reads contracts; humans approve; ledger-core posts. Sibling to ledger-core and recon.",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:diff": "prisma migrate diff --from-url \"$DATABASE_URL\" --to-schema-datamodel prisma/schema.prisma --script",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:e2e": "tsx scripts/smoke-test-e2e.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.98.0",
    "@clerk/nextjs": "6.39.4",
    "@prisma/client": "5.22.0",
    "clsx": "2.1.1",
    "decimal.js": "10.6.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.6.1",
    "zod": "4.4.3",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "10.4.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.5.15",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.19",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
