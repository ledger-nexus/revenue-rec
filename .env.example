# Postgres — point this at the SAME database as ledger-core. revenue-rec's
# Prisma schema mirrors ledger-core's models (read access) + adds its
# own (ContractDocument, RecognitionSchedule, RecognitionEvent, etc.).
# Only ledger-core runs `prisma db push` to manage the shared substrate
# tables; revenue-rec's `db push` adds its own tables on top.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledger_core?schema=public"

# Anthropic API key for the AI contract extractor. Without it, you can
# still browse contracts and post recognition periods that already
# exist in the DB — but "Re-run AI extraction" will error out. The
# deterministic engine (SSP allocator + schedule generator + posting
# via the bridge) works independently of the AI.
ANTHROPIC_API_KEY=""

# Cross-repo bridge to ledger-core's postJournalEntry. revenue-rec POSTs
# recognition JEs (and v0.2-beta will also post deferred-revenue setup
# entries) to ledger-core's /api/internal/journal-entries endpoint.
# Both repos must share the same token value.
LEDGER_CORE_URL="http://localhost:3000"
LEDGER_CORE_INTERNAL_TOKEN=""
