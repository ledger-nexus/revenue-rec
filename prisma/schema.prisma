// revenue-rec Prisma schema.
//
// Two halves:
//
//   1. ledger-core models revenue-rec QUERIES (LegalEntity, Book, Party,
//      JournalEntry, JournalLine, RevenueContract, PerformanceObligation,
//      RevenueContractBookAttributes). These mirror the canonical
//      definitions in ledger-core's schema — column-for-column.
//      revenue-rec does NOT migrate these tables; ledger-core owns the
//      schema. If ledger-core's schema changes upstream, this copy MUST
//      be re-synced.
//
//   2. revenue-rec-specific models OWNED by this repo (ContractDocument,
//      AiExtractionSuggestion, RecognitionSchedule, RecognitionEvent).
//      These live only here; `prisma db push` from this repo creates them
//      on top of ledger-core's tables.
//
// Shared Postgres: revenue-rec connects with the same DATABASE_URL as
// ledger-core. Same arrangement as recon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// ledger-core mirror — DO NOT EDIT without syncing upstream
// =========================================================================

model LegalEntity {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // SECURITY (pen-test pass 4): tenantId added so Server Actions can
  // tenant-scope their record lookups. Column exists in the shared DB.
  tenantId             String  @db.Uuid
  code                 String
  name                 String
  parentEntityId       String? @db.Uuid
  functionalCurrencyId String
  sourceSystem         String?
  sourceRecordType     String?
  sourceRecordId       String?
  sourcePayload        Json?
  mappingVersion       String?
  extensions           Json?

  journalEntries   JournalEntry[]
  revenueContracts RevenueContract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_entity")
}

model Book {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String  @unique
  name                String
  basis               BookBasis
  reportingCurrencyId String
  isActive            Boolean @default(true)
  extensions          Json?

  journalEntries   JournalEntry[]
  contractBookAttrs RevenueContractBookAttributes[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("book")
}

model Party {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId      String? @db.Uuid
  code          String
  displayName   String
  parentPartyId String? @db.Uuid

  journalLines     JournalLine[]
  revenueContracts RevenueContract[] @relation("ContractCustomer")

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, code])
  @@map("party")
}

model JournalEntry {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Phase 4b: entryNumber unique per [tenantId, entryNumber] in ledger-core.
  // No tenantId in this mirror; drop @unique, callers use findFirst.
  entryNumber  String
  entityId     String      @db.Uuid
  entity       LegalEntity @relation(fields: [entityId], references: [id])
  bookId       String      @db.Uuid
  book         Book        @relation(fields: [bookId], references: [id])
  periodId     String?     @db.Uuid
  documentDate DateTime    @db.Date
  postingDate  DateTime    @db.Date
  memo         String
  currencyId   String
  fxRate       Decimal     @default(1) @db.Decimal(20, 10)
  source       JournalSource @default(MANUAL)
  status       EntryStatus   @default(POSTED)
  reversalOfId String?     @db.Uuid

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  lines JournalLine[]

  // Backref to revenue-rec's recognition events.
  recognitionEvents RecognitionEvent[]

  createdAt DateTime @default(now())
  createdBy String?

  @@index([entityId, bookId, documentDate])
  @@map("gl_entry_header")
}

model JournalLine {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entryId   String       @db.Uuid
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo    Int
  accountId String       @db.Uuid

  partyId        String? @db.Uuid
  party          Party?  @relation(fields: [partyId], references: [id])
  itemId         String? @db.Uuid
  dimensionSetId String? @db.Uuid
  taxCodeId      String?

  debit  Decimal @default(0) @db.Decimal(18, 4)
  credit Decimal @default(0) @db.Decimal(18, 4)

  transactionAmount     Decimal @default(0) @db.Decimal(18, 4)
  transactionCurrencyId String?
  reportingAmount       Decimal @default(0) @db.Decimal(18, 4)
  reportingCurrencyId   String?

  description String?
  extensions  Json?

  @@unique([entryId, lineNo])
  @@index([accountId])
  @@map("gl_entry_line")
}

model RevenueContract {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId           String                @db.Uuid
  entity             LegalEntity           @relation(fields: [entityId], references: [id])
  code               String
  description        String
  customerPartyId    String                @db.Uuid
  customer           Party                 @relation("ContractCustomer", fields: [customerPartyId], references: [id])
  contractStartDate  DateTime              @db.Date
  contractEndDate    DateTime?             @db.Date
  totalContractValue Decimal               @db.Decimal(18, 4)
  currencyId         String
  status             RevenueContractStatus @default(ACTIVE)

  performanceObligations PerformanceObligation[]
  bookAttributes         RevenueContractBookAttributes[]

  // Backrefs into revenue-rec's owned tables.
  document            ContractDocument?
  aiSuggestions       AiExtractionSuggestion[]
  recognitionSchedules RecognitionSchedule[]
  recognitionEvents    RecognitionEvent[]

  sourceSystem     String?
  sourceRecordType String?
  sourceRecordId   String?
  sourcePayload    Json?
  mappingVersion   String?
  extensions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, code])
  @@map("revenue_contract")
}

model PerformanceObligation {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId         String          @db.Uuid
  contract           RevenueContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  sequenceNo         Int
  description        String
  ssp                Decimal         @db.Decimal(18, 4)
  recognitionPattern RecognitionPattern
  startDate          DateTime        @db.Date
  endDate            DateTime?       @db.Date
  recognizedToDate   Decimal         @default(0) @db.Decimal(18, 4)

  revenueAccountCode  String
  deferredAccountCode String

  scheduleEntries RecognitionSchedule[]
  events          RecognitionEvent[]

  @@unique([contractId, sequenceNo])
  @@map("performance_obligation")
}

model RevenueContractBookAttributes {
  contractId String          @db.Uuid
  contract   RevenueContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  bookId     String          @db.Uuid
  book       Book            @relation(fields: [bookId], references: [id])

  recognitionBasis     RecognitionBasis @default(ACCRUAL)
  cumulativeRecognized Decimal @default(0) @db.Decimal(18, 4)

  @@id([contractId, bookId])
  @@map("revenue_contract_book_attributes")
}

// =========================================================================
// revenue-rec-owned models — managed by THIS repo
// =========================================================================

// The raw contract text (or, in v0.2, a PDF reference). The AI extractor
// reads from here. We keep the verbatim source so a human can always
// audit "what did the AI see vs. what did we structure."
model ContractDocument {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId    String          @unique @db.Uuid
  contract      RevenueContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  filename      String?
  rawText       String
  format        String          @default("TEXT")  // TEXT | PDF (v0.2)
  uploadedAt    DateTime        @default(now())
  uploadedBy    String?

  @@map("contract_document")
}

// Every AI extraction run is logged here, even if the human rejects it.
// Mirrors recon's AiSuggestion table — same audit principle.
model AiExtractionSuggestion {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId      String          @db.Uuid
  contract        RevenueContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // SECURITY (pen-test pass 4 follow-up): tenantId stamped on every new
  // row so the audit page can filter without joining through
  // contract.entity. Nullable to keep db push non-destructive; backfill
  // via prisma/backfill-ai-extraction-suggestion-tenant.sql. New rows
  // always get tenantId from extractContractAction's requireCurrentTenant().
  tenantId        String?         @db.Uuid
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])

  // The model's structured extraction: array of {description, ssp,
  // recognitionPattern, startDate, endDate, rationale}.
  obligationsJson Json
  // The model's allocation suggestion, if it ran (optional in v0.2).
  allocationJson  Json?

  modelName        String
  promptHash       String?
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([tenantId, createdAt])
  @@map("ai_extraction_suggestion")
}

// One row per (PO, accounting period) that the recognition engine plans
// to recognize. Generated at contract approval time. Status flips from
// PLANNED → POSTED as the month-end runner fires.
//
// Storing the full schedule (vs. computing on demand) lets the UI render
// it as a table the user can review and approve before any posting
// happens. It's also the audit trail of "what we planned vs. what we
// actually did."
model RecognitionSchedule {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId        String                @db.Uuid
  contract          RevenueContract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  obligationId      String                @db.Uuid
  obligation        PerformanceObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  bookCode          String

  periodStart       DateTime              @db.Date
  periodEnd         DateTime              @db.Date
  plannedAmount     Decimal               @db.Decimal(18, 4)
  status            String                @default("PLANNED")  // PLANNED | POSTED | SKIPPED

  // Backref: which RecognitionEvent posted this schedule entry (null if PLANNED).
  postedByEventId   String?               @db.Uuid

  createdAt DateTime @default(now())

  @@unique([obligationId, bookCode, periodStart])
  @@index([contractId, bookCode, periodStart])
  @@index([status])
  @@map("recognition_schedule")
}

// One row per actual recognition JE posted via ledger-core. v0.1 ships
// the schema but the posting logic ships in v0.2 alongside the bridge
// integration.
model RecognitionEvent {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId      String                @db.Uuid
  contract        RevenueContract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  obligationId    String                @db.Uuid
  obligation      PerformanceObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  bookCode        String

  periodStart     DateTime              @db.Date
  periodEnd       DateTime              @db.Date
  amount          Decimal               @db.Decimal(18, 4)

  // The JE that ledger-core posted, returned by the HTTP bridge.
  postedEntryId   String                @db.Uuid
  postedEntry     JournalEntry          @relation(fields: [postedEntryId], references: [id])
  entryNumber     String

  postedAt        DateTime              @default(now())
  postedBy        String?

  @@index([contractId, bookCode, periodStart])
  @@map("recognition_event")
}

// =========================================================================
// Enums mirrored from ledger-core. MUST stay in sync.
// =========================================================================

enum BookBasis {
  US_GAAP
  US_TAX
  IFRS
  MGMT
  STATUTORY
}

enum JournalSource {
  MANUAL
  SEED
  SYSTEM
  AI_APPROVED
  IMPORT
}

enum EntryStatus {
  DRAFT
  POSTED
  VOID
  REVERSED
}

enum RevenueContractStatus {
  DRAFT
  ACTIVE
  AMENDED
  TERMINATED
  COMPLETED
}

enum RecognitionPattern {
  POINT_IN_TIME
  OVER_TIME_STRAIGHT
  OVER_TIME_USAGE
  OVER_TIME_MILESTONE
}

enum RecognitionBasis {
  ACCRUAL
  CASH
}

// Shared multi-tenancy tables (managed by ledger-core; revenue-rec
// reads them for tenant resolution). Pen-test pass 4.
model User {
  id          String  @id @db.Uuid
  email       String  @unique
  displayName String
  isActive    Boolean @default(true)
  memberships TenantMembership[]

  @@map("app_user")
}

model Tenant {
  id                      String                   @id @db.Uuid
  slug                    String                   @unique
  name                    String
  /// See ledger-core's Tenant.monthlyAiSpendCapUsd. Read-only here;
  /// revenue-rec never writes this column.
  monthlyAiSpendCapUsd    Decimal?                 @db.Decimal(10, 2)
  memberships             TenantMembership[]
  aiExtractionSuggestions AiExtractionSuggestion[]
  rateLimitEvents         RateLimitEvent[]
  aiSpendAlerts           AiSpendAlert[]

  @@map("tenant")
}

/// Spend-threshold alerts. See src/lib/auth/ai-budget.ts. Mirror of
/// fa-amort's table; revenue-rec tracks its own Opus extraction spend
/// independently.
model AiSpendAlert {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  monthKey  String
  threshold Int
  capUsd    Decimal  @db.Decimal(10, 2)
  spentUsd  Decimal  @db.Decimal(10, 2)
  sentAt    DateTime @default(now())

  @@unique([tenantId, monthKey, threshold])
  @@index([tenantId, sentAt])
  @@map("ai_spend_alert")
}

/// Per-action rate-limit ledger. See src/lib/auth/ai-budget.ts.
/// Mirrors fa-amort's RateLimitEvent; shared concept, per-repo table.
model RateLimitEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?  @db.Uuid
  action    String
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@map("rate_limit_event")
}

model TenantMembership {
  tenantId String @db.Uuid
  userId   String @db.Uuid
  role     String

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@map("tenant_membership")
}
